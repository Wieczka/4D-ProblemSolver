# MCP Server
MCP_HOST="localhost"
MCP_PORT=8000
MCP_NAME="triz-mcp-server"

# LLM Credentials
# Get an API key from Google AI Studio: https://aistudio.google.com/
GOOGLE_API_KEY="your-google-ai-studio-api-key"

# Set to 1 to use GCP Vertex AI (requires authenticated Application Default Credentials).
# Defaults to 0 (uses Google AI Studio Gemini API with GOOGLE_API_KEY).
GOOGLE_GENAI_USE_VERTEXAI=0